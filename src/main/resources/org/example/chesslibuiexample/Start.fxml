<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="30.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.chesslibuiexample.controller.StartController"
      prefWidth="400.0" prefHeight="300.0">
   <children>
      <Label text="Chess" style="-fx-font-size: 36px; -fx-font-weight: bold;" />
      <Button fx:id="localPlayButton" text="Local Play" prefWidth="180.0" prefHeight="45.0"
              style="-fx-font-size: 16px;" onAction="#onLocalPlay" />
      <Button fx:id="multiplayerButton" text="Multiplayer" prefWidth="180.0" prefHeight="45.0"
              style="-fx-font-size: 16px;" onAction="#onMultiplayer" />
   </children>
</VBox>
